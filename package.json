{
  "name": "qr-code-scanner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:pages": "node scripts/write-dev-vars.mjs && npm run build && wrangler pages dev dist --compatibility-date=2026-06-05 --ip 127.0.0.1",
    "build": "node scripts/write-ads-txt.mjs && tsc -b && vite build",
    "preview": "vite preview",
    "pages:dev": "node scripts/write-dev-vars.mjs && wrangler pages dev dist --compatibility-date=2026-06-05 --ip 127.0.0.1",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260605.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.49.1",
    "qrcode": "^1.5.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vitest": "^2.1.8",
    "wrangler": "^4.98.0"
  }
}
